{
  "expo": {
    "name": "SMS Gateway",
    "slug": "sms-gateway-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "sms-gateway-app",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d1117"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.smsgateway.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Used to scan the QR code from your dashboard to connect this device as an SMS gateway."
      }
    },
    "android": {
      "package": "com.smsgateway.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.SEND_SMS",
        "android.permission.READ_SMS"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      ["expo-router", { "origin": "https://replit.com/" }],
      "expo-font",
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow SMS Gateway to use the camera to scan the QR code from your dashboard."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
